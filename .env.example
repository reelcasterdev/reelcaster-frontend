# ReelCaster Frontend — Environment Variables
# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# ----------------------------------------------------------------
# Supabase (existing)
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------
# BlueCaster API (existing — verify present)
# ----------------------------------------------------------------
BLUECASTER_API_URL=
BLUECASTER_API_KEY=

# ----------------------------------------------------------------
# Mapbox + Weather (existing)
# ----------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=
NEXT_PUBLIC_WINDY_API_KEY=

# ----------------------------------------------------------------
# Email (existing — Resend)
# ----------------------------------------------------------------
RESEND_API_KEY=

# ----------------------------------------------------------------
# Cron auth (existing)
# ----------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------
# Stripe (Phase 5 — pricing + paywall)
# ----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Annual Season Pass ($79/yr)
STRIPE_PRICE_ANNUAL=

# Monthly seasonal Prices — one Stripe Price per calendar month.
# Approximate values (Casey to confirm):
#   Dec/Jan/Feb  = $5/mo
#   Mar/Apr/Oct/Nov = $10/mo
#   May/Jun/Jul/Aug/Sep = $15/mo
STRIPE_PRICE_MONTHLY_JAN=
STRIPE_PRICE_MONTHLY_FEB=
STRIPE_PRICE_MONTHLY_MAR=
STRIPE_PRICE_MONTHLY_APR=
STRIPE_PRICE_MONTHLY_MAY=
STRIPE_PRICE_MONTHLY_JUN=
STRIPE_PRICE_MONTHLY_JUL=
STRIPE_PRICE_MONTHLY_AUG=
STRIPE_PRICE_MONTHLY_SEP=
STRIPE_PRICE_MONTHLY_OCT=
STRIPE_PRICE_MONTHLY_NOV=
STRIPE_PRICE_MONTHLY_DEC=

# ----------------------------------------------------------------
# Twilio (Phase 6 — SMS alerts)
# ----------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Twilio Verify service for OTP phone verification
TWILIO_VERIFY_SID=

# ----------------------------------------------------------------
# PostHog (Phase 10 — analytics, replaces Mixpanel)
# ----------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------
# Google OAuth (Phase 4)
# ----------------------------------------------------------------
# Google client ID + secret are configured in the Supabase dashboard
# (Authentication → Providers → Google). No code-level env needed.

# ----------------------------------------------------------------
# Mixpanel (LEGACY — kept for now; removed in Phase 10)
# ----------------------------------------------------------------
NEXT_PUBLIC_MIXPANEL_TOKEN=
