# Copy to .env.test (gitignored) and fill in values for the test environment.
# Test users live in a dedicated Supabase project, NOT prod.

# Frontend dev server
PLAYWRIGHT_PORT=3004
PLAYWRIGHT_BASE_URL=http://localhost:3004

# Bluecaster (set when running BC-dependent specs)
BLUECASTER_URL=http://localhost:3001
BLUECASTER_PUBLIC_API_KEY=

# Stripe TEST MODE only (sk_test_..., whsec_test_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase admin key for the test project (used to flip user tier in fixtures)
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Test user credentials (use +playwright tag for easy cleanup)
TEST_FREE_USER_EMAIL=playwright-free@reelcaster.test
TEST_FREE_USER_PASSWORD=
TEST_PRO_USER_EMAIL=playwright-pro@reelcaster.test
TEST_PRO_USER_PASSWORD=
